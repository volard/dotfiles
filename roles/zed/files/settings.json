// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ssh_connections": [
    {
      "host": "elba_senko_communication",
      "args": [],
      "projects": [
        {
          "paths": ["/opt"]
        }
      ]
    }
  ],
  "format_on_save": "off",
  "diff_view_style": "unified",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "languages": {
    "JavaScript": {
      "format_on_save": "off"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "edit_predictions": {
    "mode": "eager"
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "codex-acp": {
      "default_config_options": {
        "mode": "full-access"
      },
      "type": "registry"
    }
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "fallback_branch_name": "main",
    "tree_view": true,
    "dock": "left"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": true,
  // "vim": {
  //   "enable_vim_sneak": true,
  // },
  "scrollbar": {
    "show": "never"
  },
  // File syntax highlighting
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"]
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_sign_in": false
  },
  "project_panel": {
    "dock": "left",
    "git_status": true
  },
  "auto_install_extensions": {
    "just": true,
    "dockerfile": true,
    "docker-compose": true,
    "material-icon-theme": true,
    "catppuccin": true,
    "editorconfig": true,
    "ini": true,
    "log": true
  },
  // Which-key popup settings
  "which_key": {
    // Whether to show the which-key popup when holding down key combinations.
    "enabled": true,
    // Delay in milliseconds before showing the which-key popup.
    "delay_ms": 1000
  },
  // File scan exclusions, hide on the file explorer and search
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/node_modules"
  ],
  "hide_mouse": "on_typing_and_movement",
  "tab_bar": {
    "show": false
  },
  "gutter": {
    "line_numbers": false
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Material Icon Theme"
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Catppuccin Mocha"
  }
}
