# peon preview task.complete


# ============================================================================
# ZOXIDE
# ============================================================================
if command -v zoxide &> /dev/null; then
  eval "$(zoxide init zsh)"
fi



# ============================================================================
# ATUIN
# ============================================================================
#
# should be in end to override CRTL+R
if command -v atuin &> /dev/null; then
  # . "$HOME/.atuin/bin/env"
  eval "$(atuin init zsh)"
fi



