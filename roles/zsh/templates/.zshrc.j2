# ============================================================================
# Zinit Plugin Manager Setup
# ============================================================================
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"



# ============================================================================
# Provisioning
# ============================================================================
#
# === Update Zinit & Plugins Function ===
zsh-update() {
  echo "🔄 Updating Zinit and plugins..."
  zinit self-update && zinit update --all
  echo "✅ All Zinit plugins updated!"
}

# === Optional: Add system-wide updates too ===
dev-update() {
  echo "🛠️ Updating system tools..."
  brew update && brew upgrade
  rustup update
  starship upgrade
  zsh-update
  echo "🎉 Everything's fresh and clean!"
}


# just run
# > zsh-update
# or
# > dev-update



# ============================================================================
# Plugins
# ============================================================================

# === Load OMZ libs we need (not the whole thing)
zinit snippet OMZL::git.zsh
zinit snippet OMZL::theme-and-appearance.zsh
zinit snippet OMZL::async_prompt.zsh # Non-blocking git status in prompt

# === theme
ZSH_THEME="dstufft"
zinit snippet OMZT::dstufft

# === autosuggestions and completions
zinit light zsh-users/zsh-autosuggestions # Suggests commands as you type based on your history
zinit snippet OMZP::git # 150+ git aliases (gst, gco, gp, etc.)
zinit snippet OMZP::sudo

# === styling
zinit light zsh-users/zsh-syntax-highlighting
zinit snippet OMZL::theme-and-appearance.zsh  # Terminal title, ls colors

# === eza
# config goes first
zstyle ':omz:plugins:eza' 'dirs-first' yes
zstyle ':omz:plugins:eza' 'git-status' yes
zstyle ':omz:plugins:eza' 'header' yes
zstyle ':omz:plugins:eza' 'icons' yes
zinit snippet OMZP::eza


# === fzf-tab
# config goes first
export FZF_CTRL_T_OPTS="
  --walker-skip .git,node_modules,target,.pnpm
  --preview 'bat -n --color=always {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza -1 --color=always $realpath'
zinit light Aloxaf/fzf-tab




# ============================================================================
# Completions
# ============================================================================
#
# === Load completions efficiently (after prompt is ready)
autoload -Uz compinit
compinit



# ============================================================================
# EDITOR specific
# ============================================================================
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nvim'
fi


# ============================================================================
# ZSH specific
# ============================================================================
setopt autocd # type a dir to cd
setopt auto_param_slash # when a dir is completed, add a / instead of a trailing space

# export LANG=en_US.UTF-8
DISABLE_AUTO_TITLE="true"

# === Keybindings
bindkey -v # Enable vi mode
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward


# ============================================================================
# ALIASES
# ============================================================================
if [ -f ~/.aliases ]; then
    . ~/.aliases
fi


# ============================================================================
# tmux sessionizer
# ============================================================================
export TESSDATA_PREFIX="/usr/share/tessdata/"

function run_tsesh() {
  exec </dev/tty
  exec <&1
  tsesh
}

zle -N run_tsesh
bindkey '^F' run_tsesh



# ============================================================================
# lfcd
# ============================================================================
LFCD="$HOME/.config/lf/lfcd.sh"
if [ -f "$LFCD" ]; then
    source "$LFCD"
fi
bindkey -s '^o' 'lfcd\n'



# ============================================================================
# Vmoption
# ============================================================================
___MY_VMOPTIONS_SHELL_FILE="${HOME}/.jetbrains.vmoptions.sh"
if [ -f "${___MY_VMOPTIONS_SHELL_FILE}" ]; then 
  . "${___MY_VMOPTIONS_SHELL_FILE}"
fi


# ============================================================================
# PATH setup
# ============================================================================
export PATH="$HOME/.local/share/gem/ruby/3.4.0/bin:$PATH"
export PATH="$HOME/dotfiles/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"
export PATH="$HOME/.config/emacs/bin:$PATH"
export PATH="$HOME/.pyenv/bin:$PATH"
export PATH="$HOME/.pyenv:$PATH"
export PATH="/var/lib/flatpak/exports/share$PATH"
export PATH="$HOME/.local/share/flatpak/exports/share:$PATH"
export PATH="$HOME/bin:$PATH"
export PATH="/usr/local/bin:$PATH"


# ============================================================================
# BUN setup
# ============================================================================
#
# completions
[ -s "/home/volard/.bun/_bun" ] && source "/home/volard/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"



# ============================================================================
# DMUX setup
# ============================================================================
#
# >>> dmux openrouter >>>
export OPENROUTER_API_KEY='{{ openrouter_api_key }}'
# <<< dmux openrouter <<<



# ============================================================================
