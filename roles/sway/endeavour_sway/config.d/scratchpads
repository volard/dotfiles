set {
    $maximize border none, move position center, resize set width 100 ppt height 100 ppt

    $term_id quake_term
    $term_under_hand  wezterm start --class $term_id

    $messenger_id org.telegram.desktop
    $messenger telegram-desktop

    $tasks_class superProductivity 
    $tasks_command superproductivity
}

for_window {
  ## main terminal
  [app_id=$term_id] move to scratchpad, scratchpad show
  [app_id=$term_id] $maximize

  ## Messenger
  [app_id=$messenger_id] move to scratchpad, scratchpad show

  ## Tasks
  [class=$tasks_class] move to scratchpad, scratchpad show
}

# Scratchpad bindsym
bindsym --to-code {
  ## Main terminal
  $mod+semicolon   exec swaymsg [app_id=$term_id] scratchpad show || exec $term_under_hand, $maximize

  ## Messenger
  $mod+o  exec swaymsg [app_id=$messenger_id] scratchpad show || exec $messenger

  ## Tasks
  $mod+t  exec swaymsg [class=$tasks_class] scratchpad show || exec $tasks_command 
}
