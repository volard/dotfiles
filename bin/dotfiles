#!/bin/bash

########################################
# Define colored output
########################################
set -e
RED='\e[31m'
GREEN='\e[32m'
YELLOW='\e[33m'
BLUE='\e[34m'
RESET='\e[0m'



########################################
# Define paths
########################################
DOTFILES_DIR="${HOME}/dotfiles"
PASSWORD_FILE_PATH="${DOTFILES_DIR}/vault-password.txt"

########################################
# Help function
########################################
show_help() {
  cat << EOF
Usage: dotfiles [OPTIONS] [ANSIBLE_ARGS]

Manage dotfiles using Ansible playbook.

OPTIONS:
  -h, --help          Show this help message
  --pull              Pull from git repository before running

ANSIBLE_ARGS:
  Any additional arguments are passed to ansible-playbook

Examples:
  dotfiles                    Run playbook without pulling first
  dotfiles --pull             Pull latest changes before running
  dotfiles --limit localhost  Run only on localhost
EOF
  exit 0
}

########################################
# Parse arguments
########################################
PULL=false
ANSIBLE_ARGS=()

for arg in "$@"; do
  case $arg in
    -h|--help)
      show_help
      ;;
    --pull)
      PULL=true
      ;;
    *)
      ANSIBLE_ARGS+=("$arg")
      ;;
  esac
done


########################################
# Determine distro
########################################
if [[ -f /etc/os-release ]]; then
  # Modern distributions use os-release file
  . /etc/os-release
  distro=${ID}
  version=${VERSION_ID}
elif [[ -f /etc/lsb-release ]]; then
  # Older Ubuntu/Debian systems
  . /etc/lsb-release
  distro=${DISTRIB_ID}
  version=${DISTRIB_RELEASE}
elif [[ -f /etc/redhat-release ]]; then
  # Older Red Hat based systems
  distro=$(cat /etc/redhat-release)
else
  # Fallback
  distro=$(uname -s)
  version=$(uname -r)
fi

echo
echo
# echo -e "==== Configuring system ===="
# echo -e "Distribution:${GREEN} ${distro} ${RESET}"
# echo -e "Version:${GREEN} ${version} ${RESET}"
# echo -e "============================"
# echo




########################################
# install git
########################################
if ! command -v git &> /dev/null; then
  if [[ ${distro} == "endeavouros" ]]; then
    sudo pacman -S git --noconfirm
  elif [[ ${distro} == "ubuntu" ]]; then
    sudo apt install git -y
  elif [[ ${distro} == "fedora" ]]; then
    sudo dnf in git -y
    sudo dnf in dnf-plugins-core -y
  fi
fi



########################################
# Clone repository or optionally pull
########################################
if ! [[ -d ${DOTFILES_DIR} ]]; then
  git clone "https://gitlab.com/dotfiles30/comma_files.git" "${DOTFILES_DIR}"
else
  if ! [[ -d "${DOTFILES_DIR}/.git" ]]; then
    git clone "https://gitlab.com/dotfiles30/comma_files.git" "${DOTFILES_DIR}"
  else
    if [[ "${PULL}" == "true" ]]; then
      git -C "${DOTFILES_DIR}" pull
    fi
  fi
fi




########################################
# Install Ansible
########################################
if ! [[ -x "$(command -v ansible || true)" ]]; then
  if [[ ${distro} == "endeavouros" ]]; then
    sudo pacman -S ansible --noconfirm
  elif [[ ${distro} == "fedora" ]]; then
    sudo dnf in ansible -y
  elif [[ ${distro} == "ubuntu" ]]; then

    # pipx is the best method to install ansible imo
    sudo apt install pipx -y

    # Add pipx to PATH
    sudo pipx ensurepath
    source ~/.bashrc

    if ! [[ ":$PATH:" == *":$DIR:"* ]]; then
      echo 'PATH="$PATH:$HOME/.local/bin"' >> ~/.bashrc
    fi

    source ~/.bashrc

    # Ansible installation itself
    pipx install --include-deps ansible
  fi
fi



########################################
# Setup password if not exists
########################################
if ! [[ -f "${DOTFILES_DIR}/vault-password.txt" ]]; then
  read -s -p "Please enter your Ansible Vault password: " ANSIBLE_PASSWORD
  echo
  # Trim leading and trailing whitespace (including tabs and newlines)
  trimmed_ANSIBLE_PASSWORD=$(echo "$ANSIBLE_PASSWORD" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
  echo "${trimmed_ANSIBLE_PASSWORD}" > "${PASSWORD_FILE_PATH}"
  chmod 600 "${PASSWORD_FILE_PATH}"
fi




########################################
# Run playbook
########################################
cd "${DOTFILES_DIR}"

python3 bin/sync_roles.py

ansible-galaxy install -r requirements.yml

# Use --ask-become-pass for secure interactive password prompt
# This is more secure than storing password in a file
# For non-interactive use, you can set ANSIBLE_BECOME_PASSWORD env var
# or use --become-password-file with a properly secured file (chmod 600)
ansible-playbook \
  --vault-password-file "${PASSWORD_FILE_PATH}" \
  --ask-become-pass \
  "${DOTFILES_DIR}/main.yml" \
  --syntax-check "${ANSIBLE_ARGS[@]}"

ansible-playbook \
  --vault-password-file "${PASSWORD_FILE_PATH}" \
  --ask-become-pass \
  "${DOTFILES_DIR}/main.yml" "${ANSIBLE_ARGS[@]}"

# vi:ft=sh:
